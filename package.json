{
  "name": "@ikenxuan/amagi-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Amagi monorepo - 抖音、B站的 web 端相关数据接口基于 Node.js 的实现",
  "keywords": [
    "api",
    "bilibili",
    "douyin",
    "kuaishou",
    "monorepo",
    "xiaohongshu"
  ],
  "homepage": "https://github.com/ikenxuan/amagi",
  "bugs": {
    "url": "https://github.com/ikenxuan/amagi/issues"
  },
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikenxuan/amagi.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "build:core": "pnpm --filter=@ikenxuan/amagi run build",
    "clean": "pnpm -r --filter=./packages/* run clean",
    "dev": "pnpm --filter=@ikenxuan/amagi run dev",
    "types-docs:build": "pnpm -r --filter=./packages/* run types-docs:build",
    "types-docs:serve": "pnpm --filter=@ikenxuan/amagi run types-docs:serve",
    "docs:dev": "pnpm --filter=docs run dev",
    "fix": "pnpm -r --filter=./packages/* run fix",
    "lint": "oxlint packages/*/src",
    "prepare": "husky",
    "sort": "pnpm -r --filter=./packages/* run sort",
    "test": "pnpm -r --filter=./packages/* run test",
    "typecheck": "pnpm -r --filter=./packages/* run typecheck"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "10.1.0",
    "globals": "17.5.0",
    "husky": "^9.1.7",
    "neostandard": "0.13.0",
    "sort-package-json": "3.6.1",
    "tinyglobby": "^0.2.16",
    "tsc-alias": "1.8.16",
    "tsdown": "^0.21.9",
    "tsx": "4.21.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@9.15.0"
}
