{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:core": "pnpm --filter @ikenxuan/amagi build",
    "build": "pnpm build:core && cross-env NODE_ENV=production next build",
    "dev": "pnpm build:core && next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint .",
    "format": "oxfmt"
  },
  "dependencies": {
    "@ikenxuan/amagi": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fumadocs-core": "16.10.0",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-twoslash": "^3.2.0",
    "fumadocs-ui": "16.10.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.9",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "twoslash": "^0.3.8",
    "winston": "^3.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "code-inspector-plugin": "^1.5.4",
    "cross-env": "10.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
